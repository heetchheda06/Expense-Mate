# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration (MongoDB Atlas URI)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/expensemate?retryWrites=true&w=majority

# JWT Token Secret
JWT_SECRET=super_secret_session_token_key_change_me_in_production

# Frontend Client URL for CORS Settings (Local & Deployed domains)
FRONTEND_URL=https://expensemate.vercel.app

# Optional AI Features: OpenAI API Key (if omitted, falls back to rule heuristics)
OPENAI_API_KEY=your_openai_api_key_here
